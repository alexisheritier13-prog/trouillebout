---
interface Props {
  icon?: "maconnerie" | "maison" | "structure";
}

const { icon = "maconnerie" } = Astro.props;
---

{
  icon === "maconnerie" && (
    <svg width="40" height="40" viewBox="0 0 32 32" fill="none" stroke="#ff7a2f" stroke-width="1.5">
      <rect x="4" y="7" width="24" height="18" />
      <line x1="4" y1="13" x2="28" y2="13" />
      <line x1="4" y1="19" x2="28" y2="19" />
      <line x1="12" y1="7" x2="12" y2="13" />
      <line x1="20" y1="13" x2="20" y2="19" />
      <line x1="12" y1="19" x2="12" y2="25" />
    </svg>
  )
}
{
  icon === "maison" && (
    <svg width="40" height="40" viewBox="0 0 32 32" fill="none" stroke="#ff7a2f" stroke-width="1.5">
      <path d="M4 15 L16 5 L28 15" />
      <rect x="8" y="15" width="16" height="12" />
      <rect x="14" y="20" width="4" height="7" />
    </svg>
  )
}
{
  icon === "structure" && (
    <svg width="40" height="40" viewBox="0 0 32 32" fill="none" stroke="#ff7a2f" stroke-width="1.5">
      <rect x="5" y="5" width="22" height="22" />
      <line x1="5" y1="5" x2="27" y2="27" />
      <line x1="27" y1="5" x2="5" y2="27" />
    </svg>
  )
}
