---
import { getEntry, getCollection } from "astro:content";

const settings = await getEntry("settings", "site");
const {
  companyName,
  footerTagline,
  phone,
  email,
  addressLine,
  postalCode,
  hours,
  copyrightYear,
  locationTag,
} = settings!.data;

const services = (await getCollection("services")).sort(
  (a, b) => a.data.order - b.data.order
);
---

<footer class="site-footer">
  <div class="footer-grid">
    <div class="footer-about">
      <div class="footer-logo">{companyName}</div>
      <p class="footer-tagline">{footerTagline}</p>
    </div>
    <div class="footer-col">
      <div class="footer-col-title">Services</div>
      <div class="footer-list">
        {services.map((s) => <span>{s.data.title}</span>)}
      </div>
    </div>
    <div class="footer-col">
      <div class="footer-col-title">Contact</div>
      <div class="footer-list">
        <span>{addressLine}, {postalCode}</span>
        <span>{phone}</span>
        <span>{email}</span>
        <span>{hours}</span>
      </div>
    </div>
  </div>
  <div class="footer-bottom">
    <span>© {copyrightYear} {companyName} Maçonnerie — Tous droits réservés</span>
    <span class="footer-location">{locationTag}</span>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--navy);
    color: var(--white);
  }

  .footer-grid {
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr;
    gap: 40px;
    padding: 70px 40px 50px;
  }

  .footer-logo {
    font-family: "Oswald", sans-serif;
    font-weight: 700;
    font-size: 38px;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .footer-tagline {
    font-size: 14px;
    line-height: 1.7;
    color: #9fb0c6;
    margin: 18px 0 0;
    max-width: 300px;
  }

  .footer-col-title {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 18px;
  }

  .footer-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
    font-size: 14px;
    color: #cdd8e6;
  }

  .footer-bottom {
    max-width: var(--max-width);
    margin: 0 auto;
    border-top: 3px solid var(--orange);
    padding: 22px 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 12px;
    color: #7e90a8;
  }

  .footer-location {
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  @media (max-width: 900px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 36px;
      padding: 56px 24px 40px;
    }

    .footer-bottom {
      flex-direction: column;
      gap: 8px;
      align-items: flex-start;
      padding: 22px 24px;
    }
  }
</style>
