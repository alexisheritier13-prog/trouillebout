---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Lightbox from "../components/Lightbox.astro";
import PlaceholderImage from "../components/PlaceholderImage.astro";
import { getEntry, getCollection, type CollectionEntry } from "astro:content";

const page = (await getEntry("pages", "realisations"))!.data;
const realisations = (await getCollection("realisations")).sort(
  (a, b) => a.data.order - b.data.order
);

const full = realisations.find((r) => r.data.size === "full");
const normal = realisations.find((r) => r.data.size === "normal");
const tall = realisations.find((r) => r.data.size === "tall");
const feature = realisations.find((r) => r.data.size === "feature");

function lightboxData(entry: CollectionEntry<"realisations">) {
  const images = [entry.data.image, ...(entry.data.gallery ?? [])].filter(Boolean);
  return {
    "data-lightbox-trigger": true,
    "data-images": JSON.stringify(images),
    "data-location": entry.data.location,
    "data-year": entry.data.year,
    "data-title": entry.data.title,
    "data-description": entry.data.description ?? "",
    "data-placeholder": `Chantier — ${entry.data.title}`,
  };
}

const filters = [
  { label: "Tout", value: "all" },
  { label: "Maçonnerie", value: "maconnerie" },
  { label: "Rénovation", value: "renovation" },
  { label: "Construction neuve", value: "construction-neuve" },
];
---

<Layout title="Réalisations">
  <Header current="realisations" />

  <section class="page-head container">
    <div class="eyebrow"><span class="rule"></span>{page.eyebrow}</div>
    <h1 class="page-title">{page.title}</h1>
    <div class="filters">
      {
        filters.map((f) => (
          <button
            type="button"
            class:list={["filter-chip", { active: f.value === "all" }]}
            data-filter={f.value}
          >
            {f.label}
          </button>
        ))
      }
    </div>
  </section>

  <section class="gallery container">
    {
      full && (
        <div class="gallery-full reveal" data-category={full.data.category} data-hover-zoom {...lightboxData(full)}>
          <PlaceholderImage
            src={full.data.image}
            alt={full.data.title}
            label="Chantier — vue large"
            height="520px"
          />
          <div class="gallery-caption">
            <span class="tag-muted">{full.data.location} · {full.data.year}</span>
            <span class="title-italic title-italic-lg">{full.data.title}</span>
          </div>
        </div>
      )
    }

    <div class="gallery-pair">
      {
        normal && (
          <div class="reveal" data-category={normal.data.category} data-hover-zoom {...lightboxData(normal)}>
            <PlaceholderImage src={normal.data.image} alt={normal.data.title} label="Chantier" height="380px" />
            <div class="gallery-caption gallery-caption-static">
              <span class="tag-muted">{normal.data.location} · {normal.data.year}</span>
              <span class="title-italic">{normal.data.title}</span>
            </div>
          </div>
        )
      }
      {
        tall && (
          <div class="reveal" data-category={tall.data.category} data-hover-zoom {...lightboxData(tall)}>
            <PlaceholderImage src={tall.data.image} alt={tall.data.title} label="Chantier" height="470px" />
            <div class="gallery-caption gallery-caption-static">
              <span class="tag-muted">{tall.data.location} · {tall.data.year}</span>
              <span class="title-italic">{tall.data.title}</span>
            </div>
          </div>
        )
      }
    </div>

    {
      feature && (
        <div class="gallery-feature" data-category={feature.data.category}>
          <div class="reveal">
            <span class="tag-muted">{feature.data.location} · {feature.data.year}</span>
            <h2 class="feature-title">{feature.data.title}</h2>
            <div class="feature-rule" />
            <p class="feature-description">{feature.data.description}</p>
          </div>
          <div class="reveal" data-hover-zoom {...lightboxData(feature)}>
            <PlaceholderImage
              src={feature.data.image}
              alt={feature.data.title}
              label="Chantier — vue verticale"
              height="520px"
            />
          </div>
        </div>
      )
    }

    <div class="load-more">
      <a href="#" class="load-more-link">{page.loadMoreLabel} →</a>
    </div>
  </section>

  <Lightbox />
  <Footer />
</Layout>

<style>
  .page-head {
    padding: 78px 40px 56px;
  }

  .page-title {
    font-weight: 700;
    font-size: 96px;
    line-height: 0.9;
    letter-spacing: 0.004em;
  }

  .filters {
    display: flex;
    gap: 10px;
    margin-top: 38px;
    flex-wrap: wrap;
  }

  .filter-chip {
    font-family: "Archivo", sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #5a6b82;
    background: var(--white);
    border: 1px solid var(--border-chip);
    padding: 9px 18px;
    cursor: pointer;
    transition: background-color 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  }

  .filter-chip.active {
    color: var(--white);
    background: var(--orange);
    border-color: var(--orange);
  }

  .filter-chip:not(.active):hover {
    border-color: var(--orange);
    color: var(--navy);
  }

  .gallery {
    padding: 0 40px 40px;
  }

  .gallery-full {
    position: relative;
    margin-bottom: 24px;
  }

  .gallery-caption {
    position: absolute;
    left: 24px;
    bottom: 24px;
    display: flex;
    align-items: baseline;
    gap: 16px;
  }

  .gallery-pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    align-items: start;
    margin-bottom: 24px;
  }

  .gallery-caption-static {
    position: static;
    margin-top: 14px;
    gap: 14px;
  }

  .tag-muted {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .gallery-full .tag-muted {
    color: var(--white);
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.6);
  }

  .title-italic {
    font-family: "Oswald", sans-serif;
    font-weight: 500;
    font-style: italic;
    font-size: 21px;
    color: var(--navy);
  }

  .title-italic-lg {
    font-size: 24px;
    color: var(--white);
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.5);
  }

  .gallery-feature {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
    padding: 40px 0 24px;
  }

  .feature-title {
    font-family: "Oswald", sans-serif;
    font-weight: 500;
    font-style: italic;
    font-size: 34px;
    line-height: 1.05;
    color: var(--navy);
    margin: 12px 0 0;
    text-transform: none;
  }

  .feature-rule {
    width: 48px;
    height: 2px;
    background: var(--orange);
    margin: 22px 0;
  }

  .feature-description {
    font-size: 15px;
    line-height: 1.7;
    color: var(--text);
    margin: 0;
    max-width: 380px;
  }

  .load-more {
    text-align: center;
    padding: 40px 0 20px;
    border-top: 1px solid var(--border);
    margin-top: 24px;
  }

  .load-more-link {
    font-family: "Oswald", sans-serif;
    font-weight: 500;
    font-size: 22px;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--navy);
    text-decoration: underline;
    text-decoration-color: var(--orange);
    text-underline-offset: 6px;
    text-decoration-thickness: 2px;
  }

  [data-category].is-hidden {
    display: none;
  }

  @media (max-width: 900px) {
    .page-title {
      font-size: 52px;
    }

    .gallery-pair,
    .gallery-feature {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }
</style>

<script>
  const chips = document.querySelectorAll<HTMLButtonElement>(".filter-chip");
  const items = document.querySelectorAll<HTMLElement>("[data-category]");

  chips.forEach((chip) => {
    chip.addEventListener("click", () => {
      chips.forEach((c) => c.classList.remove("active"));
      chip.classList.add("active");
      const filter = chip.dataset.filter;

      items.forEach((item) => {
        const matches = filter === "all" || item.dataset.category === filter;
        item.classList.toggle("is-hidden", !matches);
      });
    });
  });
</script>
